// TEST_INSTRUCTIONS2.dat
// Format: $readmemb — one BYTE per line, MSB first (big-endian)
// 128 bytes total = 32 instructions
//
// ┌─────────────────────────────────────────────────────────┐
// │  TEST PROGRAM 2 (RV32I - supported instructions only)   │
// │  PC=0   addi x1, x0, 5       -> x1 = 5                     │
// │  PC=4   addi x2, x0, 3       -> x2 = 3                     │
// │  PC=8   add  x3, x1, x2      -> x3 = 8  (EX forwarding)    │
// │  PC=12  sub  x4, x1, x2      -> x4 = 2  (EX forwarding)    │
// │  PC=16  sw   x3, 0(x0)       -> mem[0] = 8                 │
// │  PC=20  lw   x5, 0(x0)       -> x5 = 8  (load-use stall)   │
// │  PC=24  addi x6, x0, 12      -> x6 = 12 (0b1100)           │
// │  PC=28  addi x7, x0, 10      -> x7 = 10 (0b1010)           │
// │  PC=32  and  x8, x6, x7      -> x8 = 8  (1100 & 1010 = 1000)│
// │  PC=36  or   x9, x6, x7      -> x9 = 14 (1100 | 1010 = 1110)│
// │  PC=40  beq  x3, x5, +8      -> branch taken, PC jumps ahead│
// │  PC=44  addi x10, x0, 99     -> FLUSHED, x10 must stay 0   │
// │  PC=48  addi x10, x0, 77     -> FLUSHED, x10 must stay 0   │
// │  PC=52  addi x11, x0, 55     -> x11 = 55 (branch target)   │
// │  PC=56+ NOP (pipeline drain)                            │
// └─────────────────────────────────────────────────────────┘

